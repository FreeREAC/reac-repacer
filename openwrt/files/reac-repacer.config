# /etc/config/reac-repacer — multiport REAC Wi-Fi de-jitter re-pacer.
#
# ONE daemon handles every REAC port on a single shared clock (the ports of one
# mixer share its word clock, so they stay sample-phase-aligned). Global settings
# live in the 'repacer' section; each 'port' section is one REAC zone, mapping a
# tunnel-side in_iface (the WDS gretap VLAN subif) to a stagebox-side out_iface.
# The init takes each port out of the bridge (raw L2 TX needs standalone DSA
# ports). Disabled ports are skipped, and the daemon also auto-detects which
# ports actually carry REAC, pacing only those — so one config covers any number
# of connected stageboxes, including ones patched in after start.
#
# Latency is self-tuning: it starts at 'prefill_ms', sizes the buffer to the
# observed burst depth, and drains down to the lowest clean latency by clock rate
# alone (never by dropping a frame). 'auto_rate' detects 44.1/48/96 kHz from the
# wire at startup and live; set it 0 and 'rate' to pin it from the web UI.

config repacer 'main'
	option enabled '1'
	option prefill_ms '16'          # startup buffer (ms); drains to the link's floor
	option adapt '1'                # size the buffer to the observed burst depth
	option auto_rate '1'            # detect 44.1 / 48 / 96 kHz from the wire (startup + live)
	# option rate '48000'          # pinned rate (used only when auto_rate=0)
	option servo_clamp_ppm '700'    # max clock bias for latency reclaim (~1 cent, inaudible)
	option cpu '3'                  # real-time pacing core (isolate from the NIC IRQ core)
	option bcast_only '1'           # de-jitter only the master broadcast
	option unbridge '1'             # take each port out of the bridge at start

config port 'a'
	option enabled '1'
	option in_iface 'reactap.11'    # tunnel side
	option out_iface 'lan1'         # stagebox side

config port 'b'
	option enabled '1'
	option in_iface 'reactap.12'
	option out_iface 'lan2'

config port 'c'
	option enabled '1'
	option in_iface 'reactap.13'
	option out_iface 'lan3'
